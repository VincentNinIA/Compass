# Server-only standard API key used by exercise photo parsing, teacher drafting
# and POST /api/realtime/session.
# Never prefix this name with NEXT_PUBLIC_ and never commit a real value.
OPENAI_API_KEY=

# Production demo protection. Vercel Production fails closed when either value
# is missing or invalid. Generate the access hash with the T24 helper script;
# keep the plaintext access code outside Git and rotate both values to revoke.
COMPASS_DEMO_PROTECTION_ENABLED=0
COMPASS_DEMO_ACCESS_HASH=
COMPASS_DEMO_SESSION_SECRET=
COMPASS_DEMO_SESSION_TTL_SECONDS=14400

# T25 classroom pilot. All values are server-only. PostgreSQL is mandatory
# outside explicit automated tests; never set the memory/test flags in Vercel.
COMPASS_CLASSROOM_ENABLED=0
COMPASS_PILOT_TEACHER_ACCESS_HASH=
COMPASS_PILOT_TEACHER_SUBJECT=pilot-teacher-1
COMPASS_CLASSROOM_SESSION_SECRET=
DATABASE_URL=
